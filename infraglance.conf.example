# Copy this file to infraglance.conf and edit it for your AWS accounts.

REPORT_TITLE="InfraGlance"

# Partition controls region behavior and validation:
#   auto       - detect from credentials where possible
#   aws        - AWS commercial partition
#   aws-us-gov - AWS GovCloud (US) partition
PARTITION="auto"

# Output and temporary data locations. Relative paths are resolved from the
# directory where you run the script.
OUTPUT_DIR="./site"
WORK_DIR="./data"

# Optional S3 bucket for publishing generated HTML and raw JSON.
# Leave S3_BUCKET empty to skip publishing.
S3_BUCKET=""
S3_PREFIX="infraglance"
S3_PROFILE=""

# Redaction controls for generated HTML reports.
REDACT_PRIVATE_IPS="false"
REDACT_PUBLIC_IPS="false"
REDACT_INSTANCE_NAMES="false"
REDACT_DB_NAMES="false"
REDACT_VPC_CIDRS="false"

# VPCs are grouped by this tag when no manual VPC_IDS_* mapping exists.
ENVIRONMENT_TAG_KEY="Environment"
AUTO_DISCOVER_VPCS="true"

# Cost governance settings. pricing.json is a static hourly price table.
PRICING_FILE="./pricing.json"
MONTHLY_HOURS="730"
STOPPED_AMBER_DAYS="7"
STOPPED_RED_DAYS="30"

# Comma-separated list of tag keys that must be present on all EC2 and RDS resources.
# Leave empty to disable tagging compliance checks.
# Example: REQUIRED_TAGS="Environment,Owner,CostCenter,Project"
REQUIRED_TAGS=""

# Slack incoming webhook URL for post-scan summary notifications.
# Leave empty to disable. Create a webhook at api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

# Report sections. You can add more names, for example "Dev" or "Security".
ENVIRONMENTS=(
  "Prod"
  "Stage"
  "Common"
)

# Accounts to scan. Each account key is used in variable names below.
ACCOUNTS=(
  "main"
)

# Account: main
# Leave PROFILE and ROLE_ARN empty to use the default AWS credential chain.
# On EC2, that means the instance profile/role is used automatically.
ACCOUNT_main_LABEL="Main"
ACCOUNT_main_PROFILE=""
ACCOUNT_main_ROLE_ARN=""
ACCOUNT_main_ROLE_SESSION_NAME="infraglance-main"
ACCOUNT_main_REGIONS=(
  # Use "auto" to discover enabled regions. With PARTITION="aws-us-gov",
  # auto scans us-gov-west-1 and us-gov-east-1.
  "us-east-1"
)

# Optional manual VPC mappings for account "main". These override tag discovery.
VPC_IDS_main_Prod=(
  "vpc-prodexample"
)

VPC_IDS_main_Stage=(
  "vpc-stageexample"
)

VPC_IDS_main_Common=(
  "vpc-commonexample"
)

# Example: add another AWS account by uncommenting this block and adding
# "shared" to ACCOUNTS above.
#
# ACCOUNT_shared_LABEL="Shared Services"
# ACCOUNT_shared_PROFILE="shared-profile"
# ACCOUNT_shared_ROLE_ARN=""
# ACCOUNT_shared_ROLE_SESSION_NAME="infraglance-shared"
# ACCOUNT_shared_REGIONS=(
#   "us-east-1"
#   "us-west-2"
# )
#
# GovCloud role ARN example:
# ACCOUNT_gov_ROLE_ARN="arn:aws-us-gov:iam::123456789012:role/infraglance-readonly"
#
# VPC_IDS_shared_Prod=(
#   "vpc-anotherprod"
# )
#
# VPC_IDS_shared_Common=(
#   "vpc-anothercommon"
# )
